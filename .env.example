# ---- API ----
PORT=3000
NODE_ENV=development
# EMBED_WORKER=true : worker BullMQ dans le même processus que l'API
# (déploiement mono-service, ex. Railway MVP — voir docs/DEPLOY_RAILWAY.md)
EMBED_WORKER=false

# ---- Base de données ----
DATABASE_URL=postgresql://brickify:brickify@localhost:5432/brickify

# ---- Redis / files de jobs ----
REDIS_URL=redis://localhost:6379

# ---- Stockage fichiers ----
# STORAGE_DRIVER=local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=brickify
S3_ACCESS_KEY=brickify
S3_SECRET_KEY=brickify123

# ---- Auth ----
# AUTH_MODE=dev : toute requête est attribuée à un utilisateur de dev (pas de token requis)
# AUTH_MODE=supabase : vérifie le JWT Supabase (HS256) via SUPABASE_JWT_SECRET
AUTH_MODE=dev
SUPABASE_JWT_SECRET=change-me

# ---- Segmentation ML (optionnel) ----
# Si défini, le détourage passe par Replicate (BiRefNet) avec repli
# automatique sur l'heuristique. Nécessite un moyen de paiement sur le compte.
# REPLICATE_API_TOKEN=r8_...
# REPLICATE_SEGMENT_MODEL=851-labs/background-remover
# REPLICATE_TIMEOUT_MS=45000

# ---- Relief / profondeur LOCALE (Depth Anything V2 Small, ONNX, CPU) ----
# Activé par défaut : relief réel sur 100% des générations, sans cold start
# ni coût par photo. Le modèle (~99 Mo) est téléchargé une fois puis mis en
# cache sous STORAGE_LOCAL_DIR/models (volume persistant en prod).
# DEPTH_LOCAL_ENABLED=true
# DEPTH_ONNX_MODEL_URL=https://huggingface.co/onnx-community/depth-anything-v2-small/resolve/main/onnx/model.onnx
# DEPTH_ONNX_MODEL_PATH=        # chemin d'un modèle pré-embarqué (court-circuite le téléchargement)
# DEPTH_MODEL_DIR=./storage/models
# DEPTH_ONNX_INPUT_SIZE=518     # multiple de 14 (ViT)
# DEPTH_ONNX_INVERT=false       # true si le relief sort inversé (creux/bosses échangés)

# ---- Mobile (apps/mobile/.env) ----
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
